# Copiá este archivo a .env y ajustá valores.
# En Docker, docker-compose inyecta MYSQL_HOST=mysql y lee el resto del .env del host.

PORT=3000

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=idiot
MYSQL_PASSWORD=idiot_secret
MYSQL_DATABASE=idiot_qc

# Obligatorio: secreto largo y aleatorio para firmar JWT (ej. openssl rand -hex 32)
JWT_SECRET=cambiar_por_un_secreto_largo_y_aleatorio
JWT_EXPIRES_IN=8h

# Solo si la tabla qc_users está vacía al arrancar: se crea este usuario.
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=cambiar_en_primer_arranque
